# App
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
COOKIE_DOMAIN=localhost

# Database
DATABASE_URL="postgresql://fieldsalesos:fieldsalesos@localhost:5432/field_sales_os?schema=public"

# Auth
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-access
JWT_REFRESH_SECRET=replace-with-a-long-random-secret-refresh

# Object storage (S3-compatible). Local dev points at the docker-compose MinIO.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=field-sales-os
STORAGE_ACCESS_KEY_ID=fieldsalesos
STORAGE_SECRET_ACCESS_KEY=fieldsalesos123
STORAGE_FORCE_PATH_STYLE=true

# Payments — MVP uses ManualPaymentProvider, no keys required yet.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
